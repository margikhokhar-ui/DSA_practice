#include <iostream>
using namespace std;

int main() {
    int arr1[] = {1, 2, 4, 5};
    int arr2[] = {2, 3, 5, 6};

    int n1 = 4, n2 = 4;
    int i = 0, j = 0;

    cout << "Union: ";

    while (i < n1 && j < n2) {
        // Skip duplicates in arr1
        if (i > 0 && arr1[i] == arr1[i - 1]) {
            i++;
            continue;
        }

        // Skip duplicates in arr2
        if (j > 0 && arr2[j] == arr2[j - 1]) {
            j++;
            continue;
        }

        if (arr1[i] < arr2[j]) {
            cout << arr1[i++] << " ";
        }
        else if (arr2[j] < arr1[i]) {
            cout << arr2[j++] << " ";
        }
        else {
            cout << arr1[i] << " ";
            i++;
            j++;
        }
    }

    // Remaining elements
    while (i < n1) {
        if (i == 0 || arr1[i] != arr1[i - 1])
            cout << arr1[i] << " ";
        i++;
    }

    while (j < n2) {
        if (j == 0 || arr2[j] != arr2[j - 1])
            cout << arr2[j] << " ";
        j++;
    }

    return 0;
}
