#include <iostream>
#include <vector>
using namespace std;

vector<int> rearrangeArray(vector<int>& nums) {
    int n = nums.size();
    vector<int> result(n);

    int pos = 0;  // index for positive numbers
    int neg = 1;  // index for negative numbers

    for (int i = 0; i < n; i++) {
        if (nums[i] > 0) {
            result[pos] = nums[i];
            pos += 2;
        } else {
            result[neg] = nums[i];
            neg += 2;
        }
    }
    return result;
}

int main() {
    vector<int> nums = {3, -1, -2, 4, -3, 5};

    vector<int> ans = rearrangeArray(nums);

    cout << "Rearranged array: ";
    for (int i = 0; i < ans.size(); i++) {
        cout << ans[i] << " ";
    }

    return 0;
}
