#include <iostream>
using namespace std;

// Function to print array
void printArray(int arr[], int n) {
    for(int i = 0; i < n; i++)
        cout << arr[i] << " ";
    cout << endl;
}

// Left Rotation
void leftRotate(int arr[], int n, int k) {
    k = k % n;
    for(int i = 0; i < k; i++) {
        int temp = arr[0];
        for(int j = 0; j < n-1; j++)
            arr[j] = arr[j+1];
        arr[n-1] = temp;
    }
}

// Right Rotation
void rightRotate(int arr[], int n, int k) {
    k = k % n;
    for(int i = 0; i < k; i++) {
        int temp = arr[n-1];
        for(int j = n-1; j > 0; j--)
            arr[j] = arr[j-1];
        arr[0] = temp;
    }
}

int main() {
    int arr1[] = {1, 2, 3, 4, 5};
    int arr2[] = {1, 2, 3, 4, 5};
    int n = 5, k = 2;

    cout << "Original Array: ";
    printArray(arr1, n);

    leftRotate(arr1, n, k);
    cout << "Left Rotated: ";
    printArray(arr1, n);

    rightRotate(arr2, n, k);
    cout << "Right Rotated: ";
    printArray(arr2, n);

    return 0;
}
