#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int arr[] = {1, 2, 3};
    int n = 3;

    // Step 1: Find pivot
    int i = n - 2;
    while (i >= 0 && arr[i] >= arr[i + 1])
        i--;

    if (i >= 0) {
        // Step 2: Find next greater element
        int j = n - 1;
        while (arr[j] <= arr[i])
            j--;

        swap(arr[i], arr[j]);
    }

    // Step 3: Reverse remaining
    reverse(arr + i + 1, arr + n);

    cout << "Next Permutation: ";
    for (int k = 0; k < n; k++)
        cout << arr[k] << " ";

    return 0;
}
