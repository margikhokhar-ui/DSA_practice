#include <iostream>
using namespace std;

int lowerBound(int arr[], int n, int key) {
    int low = 0, high = n - 1;
    int ans = n; // default if not found

    while (low <= high) {
        int mid = (low + high) / 2;

        if (arr[mid] >= key) {
            ans = mid;
            high = mid - 1; // go left
        } else {
            low = mid + 1; // go right
        }
    }
    return ans;
}

int main() {
    int arr[] = {1, 3, 3, 5, 7};
    int n = 5;
    int key = 3;

    int index = lowerBound(arr, n, key);

    cout << "Lower Bound Index: " << index;

    return 0;
}
