#include <iostream>
using namespace std;

int merge(int arr[], int low, int mid, int high) {
    int count = 0;

    // Count reverse pairs
    int j = mid + 1;
    for (int i = low; i <= mid; i++) {
        while (j <= high && arr[i] > 2 * arr[j])
            j++;
        count += (j - (mid + 1));
    }

    // Merge step
    int temp[100];
    int i = low, k = 0;
    j = mid + 1;

    while (i <= mid && j <= high) {
        if (arr[i] <= arr[j])
            temp[k++] = arr[i++];
        else
            temp[k++] = arr[j++];
    }

    while (i <= mid)
        temp[k++] = arr[i++];

    while (j <= high)
        temp[k++] = arr[j++];

    for (int i = low; i <= high; i++)
        arr[i] = temp[i - low];

    return count;
}

int mergeSort(int arr[], int low, int high) {
    int count = 0;
    if (low < high) {
        int mid = (low + high) / 2;

        count += mergeSort(arr, low, mid);
        count += mergeSort(arr, mid + 1, high);
        count += merge(arr, low, mid, high);
    }
    return count;
}

int main() {
    int arr[] = {1, 3, 2, 3, 1};
    int n = 5;

    int result = mergeSort(arr, 0, n - 1);

    cout << "Reverse Pairs: " << result;

    return 0;
}
